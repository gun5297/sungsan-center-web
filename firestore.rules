rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 헬퍼 함수 =====

    function isSignedIn() {
      return request.auth != null;
    }

    // 익명 Auth 여부 (출결 태블릿 전용)
    function isAnonymous() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // 실명 인증된 사용자 (익명 Auth 제외)
    function isNamedUser() {
      return isSignedIn() && !isAnonymous();
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // 관리자: role + approved Firestore 서버측 검증 (클라이언트 신뢰 금지)
    function isAdmin() {
      return isNamedUser()
        && getUserData().role in ['admin', 'director', 'teacher', 'social_worker']
        && getUserData().approved == true;
    }

    // 승인된 실명 사용자 (관리자 포함)
    function isApproved() {
      return isNamedUser() && getUserData().approved == true;
    }

    // 문서 필드 수 제한 — 비용 공격 방어
    function underSizeLimit() {
      return request.resource.data.size() < 30;
    }

    // ===== 필드 검증 함수 =====

    function validAbsenceCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['type', 'name', 'reason', 'from', 'date'])
        && d.keys().hasOnly(['type', 'name', 'reason', 'from', 'date', 'school', 'guardian', 'phone', 'to', 'birth', 'createdAt'])
        && d.type in ['결석', '조퇴', '지각']
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 20
        && d.reason is string && d.reason.size() >= 1 && d.reason.size() <= 500
        && d.from is string && d.from.size() <= 20
        && d.date is string && d.date.matches('^[0-9]{4}[.\\-][0-9]{2}[.\\-][0-9]{2}$');
    }

    function validMedicationCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['name', 'drug', 'dose', 'time', 'from'])
        && d.keys().hasOnly(['name', 'drug', 'dose', 'time', 'from', 'to', 'note', 'birth', 'symptom', 'hospital', 'storage', 'createdAt'])
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 20
        && d.drug is string && d.drug.size() >= 1 && d.drug.size() <= 100
        && d.dose is string && d.dose.size() <= 50
        && d.time is string && d.time.size() <= 20
        && d.from is string && d.from.size() <= 20;
    }

    function validInboxCreate() {
      let d = request.resource.data;
      return d.keys().hasAll(['type', 'name', 'date'])
        && d.keys().hasOnly(['type', 'name', 'summary', 'date', 'data', 'consents', 'receiptNo', 'createdAt'])
        && d.type in ['absence', 'medication', 'register', 'consult']
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 50
        && d.date is string && d.date.size() <= 20;
    }

    // 출결 records 필드: map(string→map) 구조 검증
    function validAttendanceWrite() {
      let d = request.resource.data;
      return d.keys().hasOnly(['records', 'date'])
        && d.date is string
        && d.date.size() == 10
        && d.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && d.records is map;
    }

    // ===== 사용자 =====
    match /users/{userId} {
      allow read: if isNamedUser() && (request.auth.uid == userId || isAdmin());
      // 가입 시: 반드시 role=general, approved=false 강제
      allow create: if isNamedUser() && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'name', 'role', 'approved'])
        && request.resource.data.keys().hasOnly(['email', 'name', 'role', 'approved', 'phone', 'photoConsent', 'consentAt', 'consentVersion', 'createdAt'])
        && request.resource.data.role == 'general'
        && request.resource.data.approved == false;
      // 본인: 이름·연락처·사진동의만 수정 가능 / 관리자: 전체 수정
      allow update: if isNamedUser() && (
        (request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['name', 'phone', 'photoConsent']))
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ===== 공지사항 — 공개 읽기 허용 =====
    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 갤러리 — 승인된 실명 사용자만 =====
    match /gallery/{itemId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // ===== 식단·시간표·픽업 — 공개 읽기 =====
    match /meals/{mealId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pickups/{pickupId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 출결 기록 =====
    // 쓰기: 익명 Auth(태블릿) + 구조 검증
    // 읽기: 승인된 실명 사용자 또는 익명(태블릿 — 당일 기록 확인용)
    match /attendance/{dateId} {
      allow read: if isApproved() || isAnonymous();
      // 태블릿(익명)은 쓰기만, 실명 관리자도 수정 가능
      allow create, update: if (isAnonymous() || isAdmin()) && validAttendanceWrite();
      allow delete: if isAdmin();
    }

    // ===== 학생 명단 — 승인된 실명 사용자만 =====
    // 태블릿은 students를 조회하지 않음 (ID만으로 출결 기록)
    match /students/{studentId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // ===== 학생 연락처 — 보호자 전화번호 분리 저장 (승인 사용자만) =====
    match /studentPhones/{studentId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    // ===== 결석/조퇴 — 제출: 로그인 또는 App Check (필드 검증) =====
    match /absences/{absenceId} {
      allow read: if isApproved();
      allow create: if validAbsenceCreate() && underSizeLimit();
      allow update, delete: if isAdmin();
    }

    // ===== 투약 — 민감정보: 관리자만 읽기 =====
    match /medications/{medId} {
      allow read: if isAdmin();
      allow create: if validMedicationCreate() && underSizeLimit();
      allow update, delete: if isAdmin();
    }

    // ===== 서류함 — 관리자만 =====
    match /inbox/{inboxId} {
      allow read: if isAdmin();
      allow create: if validInboxCreate() && underSizeLimit();
      allow update, delete: if isAdmin();
    }

    // ===== 신규 등록/상담 — 민감정보 =====
    match /registrations/{id} {
      allow create: if request.resource.data.keys().hasAll(['name', 'date'])
        && request.resource.data.keys().hasOnly(['name', 'date', 'type', 'summary', 'data', 'consents', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 50
        && underSizeLimit();
      allow read, update, delete: if isAdmin();
    }

    // ===== 설정 — 관리자만 =====
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }

    // ===== 출결 태블릿 공개 설정 (PIN 해시) =====
    match /publicConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== 감사 로그 — 추가 전용 =====
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isNamedUser()
        && request.resource.data.keys().hasAll(['action', 'userId', 'createdAt'])
        && request.resource.data.keys().hasOnly(['action', 'resource', 'resourceId', 'message', 'userId', 'createdAt'])
        && request.resource.data.action is string
        && request.resource.data.action.size() <= 100
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ===== 공지 읽음 확인 =====
    match /noticeReads/{readId} {
      allow read: if isAdmin();
      allow create: if isNamedUser()
        && request.resource.data.keys().hasOnly(['noticeId', 'userId', 'readAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.noticeId is string;
      // 업데이트 불필요 (읽음 상태는 생성으로 충분)
      allow update: if false;
      allow delete: if false;
    }

    // ===== 활동 일지 =====
    match /dailyLogs/{logId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // ===== 아동 통합 명단 — 개인정보: 승인된 실명 사용자만 =====
    match /children/{childId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // ===== 아동-보호자 연결 =====
    match /childLinks/{linkId} {
      allow read: if isApproved()
        && (resource != null && resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isApproved();
      allow update: if isAdmin();
      allow delete: if (isApproved() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // ===== 전자서명 메타데이터 =====
    match /signatures/{sigId} {
      allow read: if isApproved();
      allow create: if request.resource.data.keys().hasAll(['path', 'createdAt'])
        && request.resource.data.keys().hasOnly(['path', 'type', 'linkedTo', 'createdAt'])
        && request.resource.data.path is string
        && request.resource.data.path.size() <= 200;
      allow delete: if isAdmin();
    }

    // ===== 알림 큐 =====
    match /notifications/{notiId} {
      allow read: if isAdmin();
      allow create: if (isAnonymous() || isNamedUser())
        && request.resource.data.keys().hasAll(['type', 'createdAt'])
        && request.resource.data.keys().hasOnly(['type', 'message', 'studentId', 'createdAt'])
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 50;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ===== 기본값: 모든 미명시 경로 차단 =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
