rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 갤러리 이미지: 로그인 사용자만 읽기 / 관리자만 업로드·삭제
    match /gallery/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 전자서명: 로그인 사용자만 읽기 / 비로그인 학부모도 업로드 가능
    match /signatures/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // 공지사항 첨부파일: 누구나 읽기 / 관리자만 업로드
    match /notices/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}
