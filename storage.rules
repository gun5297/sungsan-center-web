rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== 헬퍼 함수 =====

    // 실명 인증 관리자 (Firestore role + approved 확인)
    function isAdminUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
            in ['admin', 'director', 'teacher', 'social_worker']
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.approved
            == true;
    }

    // 승인된 실명 사용자 (갤러리 읽기용)
    function isApprovedUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.approved
            == true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // 이미지 MIME 타입 검증
    function isImage() {
      return request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }

    // 파일 크기 제한 (5MB)
    function underSizeLimit() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // ===== 갤러리 이미지 =====
    // 읽기: 승인된 실명 사용자 (익명 제외)
    // 업로드·삭제: 관리자만 + 이미지 타입 + 5MB 이하
    match /gallery/{allPaths=**} {
      allow read: if isApprovedUser();
      allow write: if isAdminUser() && isImage() && underSizeLimit();
    }

    // ===== 전자서명 =====
    // 읽기: 승인된 실명 사용자 (서류 출력용)
    // 쓰기: 로그인 필수 + PNG 타입 + 100KB 제한
    match /signatures/{allPaths=**} {
      allow read: if isApprovedUser();
      allow write: if isSignedIn()
        && request.resource.contentType == 'image/png'
        && request.resource.size < 100 * 1024;
    }

    // ===== 공지사항 첨부파일 =====
    // 읽기: 누구나 (공개 공지 첨부물)
    // 업로드·삭제: 관리자만 + 5MB 이하
    match /notices/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminUser() && underSizeLimit();
    }

    // ===== 기본값: 미명시 경로 차단 =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
