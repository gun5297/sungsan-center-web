rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== 헬퍼 함수 =====
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
        getUserData().role in ['admin', 'director', 'teacher', 'social_worker'] &&
        getUserData().approved == true;
    }

    function isApproved() {
      return isSignedIn() && getUserData().approved == true;
    }

    // ===== 사용자 =====
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        (request.auth.uid == userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ===== 공지사항 =====
    match /notices/{noticeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 갤러리 =====
    match /gallery/{itemId} {
      allow read: if isApproved();
      allow create, update, delete: if isAdmin();
    }

    // ===== 식단 =====
    match /meals/{mealId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 시간표 =====
    match /schedules/{scheduleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 출결 =====
    // 태블릿 출결 시스템: 읽기/쓰기 허용하되 문서 크기 제한
    match /attendance/{dateId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['records', 'date'])
                            && request.resource.data.date is string;
      allow delete: if isAdmin();
    }

    // ===== 학생 =====
    // 태블릿 출결 시스템: 읽기 허용, 쓰기는 관리자만
    match /students/{studentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 결석/조퇴 =====
    match /absences/{absenceId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ===== 투약 =====
    match /medications/{medId} {
      allow read: if isSignedIn();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ===== 픽업 =====
    match /pickups/{pickupId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ===== 서류함 =====
    match /inbox/{inboxId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ===== 신규 등록/상담 =====
    match /registrations/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ===== 설정 (비밀번호 등) =====
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== 감사 로그 =====
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ===== 공지 읽음 확인 =====
    match /noticeReads/{readId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ===== 활동 일지 =====
    match /dailyLogs/{logId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== 아동 통합 명단 =====
    match /children/{childId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ===== 아동-보호자 연결 =====
    match /childLinks/{linkId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ===== 알림 큐 (카카오 알림톡) =====
    match /notifications/{notiId} {
      allow read: if isAdmin();
      allow create: if true; // 출결 시스템에서도 생성
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
