  </section>

  <!-- STATS -->
  <div class="stats fade-up">
    <div class="stat-card">
      <div class="stat-number">4</div>
      <div class="stat-label">참가 지역<br>NA · EMEA · Asia · China</div>
    </div>
    <div class="stat-card">
      <div class="stat-number">11</div>
      <div class="stat-label">파트너 팀<br>역대 최대 규모</div>
