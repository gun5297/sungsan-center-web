rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== 헬퍼 함수 =====

    // Firestore에서 사용자 역할 조회
    function isAdminUser() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
            in ['admin', 'director', 'teacher', 'social_worker']
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.approved
            == true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // 이미지 파일 타입 검증
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // 파일 크기 제한 (5MB)
    function underSizeLimit() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // ===== 갤러리 이미지 =====
    // 읽기: 로그인 사용자 / 업로드·삭제: 관리자만
    match /gallery/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdminUser() && isImage() && underSizeLimit();
    }

    // ===== 전자서명 =====
    // 읽기: 로그인 사용자 (서류 출력용)
    // 쓰기: 비로그인 학부모도 제출 가능 — 파일 크기 + PNG 타입 검증
    match /signatures/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if request.resource.contentType == 'image/png'
        && request.resource.size < 512 * 1024;  // 서명 이미지: 512KB 제한
    }

    // ===== 공지사항 첨부파일 =====
    // 읽기: 누구나 (공개 공지의 첨부)
    // 업로드·삭제: 관리자만
    match /notices/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminUser() && underSizeLimit();
    }

    // ===== 기본값: 미명시 경로 차단 =====
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
