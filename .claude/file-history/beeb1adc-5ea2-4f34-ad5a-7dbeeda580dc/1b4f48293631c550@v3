        <ul class="region-teams">
          <li>파트너 프로그램 합류</li>
          <li>2026 신규 추가</li>
          <li>World Finals 개최</li>
        </ul>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- SCHEDULE -->
  <section class="section fade-up" id="schedule">
    <div class="section-tag">Schedule</div>
    <h2 class="section-title">2026 시즌<br>주요 일정</h2>
    <p class="section-desc">Stage 1부터 World Finals까지, 놓치지 마세요.</p>
    <div class="schedule-list">
      <div class="schedule-item">
        <div class="schedule-date">Feb 8–15, 2026</div>
